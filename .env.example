# 3cblue environment variables
#
# Setup (Tier 2 direnv pattern):
#   1. Install direnv: https://direnv.net/
#   2. Hook into your shell (e.g. `eval "$(direnv hook bash)"` in ~/.bashrc)
#   3. Create the secrets file:
#        mkdir -p ~/.local/share/secrets && chmod 700 ~/.local/share/secrets
#        cp .env.example ~/.local/share/secrets/3cblue.env
#        chmod 600 ~/.local/share/secrets/3cblue.env
#      then fill in the values below.
#   4. From the repo root: `direnv allow .`
#   5. For Docker (env_file: .env in docker-compose.yml):
#        ln -s ~/.local/share/secrets/3cblue.env .env
#      (.env is gitignored; the symlink keeps Docker working.)

BSKY_SERVICE=https://bsky.social
BSKY_IDENTIFIER=3cblue.bsky.social
BSKY_PASSWORD=
DB_PATH=./3cblue.db
POLL_INTERVAL_MS=10000
