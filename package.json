{
  "name": "3cblue",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "biome check --write . && npm run typecheck && npm run test && npm run lint:dead",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "dev": "node --import tsx src/main.ts",
    "build": "tsc -b",
    "lint:dead": "knip && fallow dead-code",
    "lint:dead:full": "knip && fallow"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@atproto/api": "^0.13.0",
    "better-sqlite3": "^11.0.0",
    "propter-bsky-kit": "file:propter-bsky-kit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.0",
    "fallow": "2.69.0",
    "knip": "6.12.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
